<?php

/**
 * @file
 * Store Frontend Module
 * Handles custom store page and product display functionality
 */


/**
 * Implements hook_form_alter().
 * Add redirect to cart page after adding product to cart.
 */
function store_frontend_form_alter(&$form, &$form_state, $form_id) {
  // Match commerce order item forms (add to cart forms)
  if (strpos($form_id, 'add_to_cart_form') !== FALSE) {
    // Append our handler LAST so redirect happens after all other processing
    if (!isset($form['#submit'])) {
      $form['#submit'] = [];
    }
    $form['#submit'][] = 'store_frontend_add_to_cart_submit';
  }
}

/**
 * Implements hook_form_commerce_order_item_add_to_cart_form_alter().
 * Target the specific add to cart form with higher priority.
 */
function store_frontend_form_commerce_order_item_add_to_cart_form_alter(&$form, &$form_state) {
  // Add our redirect handler
  if (!isset($form['#submit'])) {
    $form['#submit'] = [];
  }
  $form['#submit'][] = 'store_frontend_add_to_cart_submit';
}

/**
 * Custom submit handler to redirect to cart page.
 */
function store_frontend_add_to_cart_submit(&$form, &$form_state) {
  // Always redirect to cart page after add to cart
  $form_state->setRedirect('commerce_cart.page');
}

/**
 * Implements hook_preprocess_commerce_product().
 * Prepares product variations form and adds product metadata for rendering.
 */
function store_frontend_preprocess_commerce_product(&$variables) {
  $product_entity = $variables['product_entity'] ?? NULL;
  
  if (!$product_entity) {
    return;
  }
  
  // Add product-specific variables
  $variables['product_id'] = $product_entity->id();
  $variables['product_bundle'] = $product_entity->bundle();
  
  // Add custom classes for styling
  $variables['attributes']['class'][] = 'commerce-product';
  $variables['attributes']['class'][] = 'commerce-product--' . str_replace('_', '-', $product_entity->bundle());
  
  // Handle multiple currency prices
  if ($product_entity->hasField('field_price') && !$product_entity->get('field_price')->isEmpty()) {
    $prices = [];
    foreach ($product_entity->get('field_price') as $price_item) {
      $prices[] = [
        'amount' => $price_item->number,
        'currency' => $price_item->currency_code,
      ];
    }
    $variables['product_prices'] = $prices;
  }
  
  // Get the default variation
  $default_variation = $product_entity->getDefaultVariation();
  if (!$default_variation) {
    return;
  }
  
  // Build the order item add to cart form
  $entity_type_manager = \Drupal::entityTypeManager();
  $form_builder = \Drupal::formBuilder();
  
  $order_item_storage = $entity_type_manager->getStorage('commerce_order_item');
  $order_item = $order_item_storage->createFromPurchasableEntity($default_variation);
  
  $form_object = $entity_type_manager->getFormObject('commerce_order_item', 'add_to_cart');
  $form_object->setEntity($order_item);
  
  $form_state = new \Drupal\Core\Form\FormState();
  $form_state->setFormState([
    'product' => $product_entity,
    'view_mode' => 'default',
    'settings' => [
      'combine' => TRUE,
    ],
  ]);
  
  // Set redirect to cart page after form submission
  $form_state->setRedirect('commerce_cart.page');
  
  // Build and assign the form to variables
  $variables['product_add_to_cart_form'] = $form_builder->buildForm($form_object, $form_state);
}

/**
 * Implements hook_theme().
 * Define custom theme hooks for store module.
 */
function store_frontend_theme($existing, $type, $theme, $path) {
  return [
    'store_product_list' => [
      'variables' => [
        'products' => NULL,
        'pager' => NULL,
      ],
      'template' => 'store-product-list',
      'path' => $path . '/templates',
    ],
    'commerce_product' => [
      'base hook' => 'commerce_product',
      'template' => 'commerce-product',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_entity_access().
 */
function store_frontend_entity_access(\Drupal\Core\Entity\EntityInterface $entity, $operation, \Drupal\Core\Session\AccountInterface $account) {
  if ($entity->getEntityTypeId() === 'commerce_product' && $operation === 'view') {
    $allowed_roles = ['administrator', 'client'];
    if (!array_intersect($allowed_roles, $account->getRoles())) {
      return \Drupal\Core\Access\AccessResult::forbidden();
    }
  }
  return \Drupal\Core\Access\AccessResult::neutral();
}

/**
 * Implements hook_user_login().
 */
function store_frontend_user_login($account) {
  // Set session flag to indicate user just logged in.
  // This will be used by the event subscriber to redirect only once.
  \Drupal::request()->getSession()->set('store_frontend_just_logged_in', TRUE);
}

/**
 * Implements hook_user_logout().
 */
function store_frontend_user_logout($account) {
  // Clear the redirect flag when user logs out.
  \Drupal::request()->getSession()->remove('store_frontend_redirected');
}

/**
 * Implements hook_user_view_alter().
 */
function store_frontend_user_view_alter(&$build, $account, $view_mode) {
  // Sirf client role ke liye.
  if (in_array('client', $account->getRoles())) {
    // Store link.
    $store_link = [
      '#type' => 'link',
      '#title' => t('Go to Store'),
      '#url' => \Drupal\Core\Url::fromRoute('store_frontend.store'),
      '#attributes' => [
        'class' => ['button', 'button--store'],
      ],
    ];
    
    // Logout link.
    $logout_link = [
      '#type' => 'link',
      '#title' => t('Logout'),
      '#url' => \Drupal\Core\Url::fromRoute('user.logout'),
      '#attributes' => [
        'class' => ['button', 'button--logout'],
      ],
    ];
    
    // Inhe user profile ke 'overview' field group mein add karte hain.
    $build['store_frontend_links'] = [
      '#weight' => 10,
      'store_link' => $store_link,
      'logout_link' => $logout_link,
    ];
  }
}