{#
/**
 * @file
 * Store page wrapper - Universal template for any products view
 */
#}

<div class="store-page">
  <div class="store-container">

    {# Store Header #}
    <div class="store-header">
      <h1 class="store-title">Our Products</h1>
      <p class="store-subtitle">Explore our collection of premium products</p>
    </div>

    {# Products Grid Container #}
    {% if rows %}
      {{ rows }}
    {% else %}
      <div class="products-empty">
        <h2>No Products Found</h2>
        <p>We're currently updating our product catalog. Please check back soon!</p>
      </div>
    {% endif %}

  </div>
</div>
