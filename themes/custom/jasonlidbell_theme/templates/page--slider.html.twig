{#
/**
 * @file
 * Theme override for gallery/category pages with slider.
 */
#}
<div class="mobile-overlay" id="mobileOverlay"></div>

<div class="container">
  {{ page.sidebar_first }}
  
  <div class="slider-container">
    <div class="slider" id="slider">
      {% if node.field_slider_images %}
        {% for image in node.field_slider_images %}
          <div class="slide {{ loop.first ? 'active zooming' : '' }}" style="background-image: url('{{ file_url(image.entity.uri.value) }}');"></div>
        {% endfor %}
      {% else %}
        {# Fallback slides if no images are set #}
        <div class="slide active zooming"></div>
        <div class="slide"></div>
        <div class="slide"></div>
        <div class="slide"></div>
        <div class="slide"></div>
      {% endif %}
    </div>

    <div class="slider-dots" id="sliderDots">
      {% if node.field_slider_images %}
        {% for image in node.field_slider_images %}
          <div class="dot {{ loop.first ? 'active' : '' }}" data-slide="{{ loop.index0 }}"></div>
        {% endfor %}
      {% else %}
        <div class="dot active" data-slide="0"></div>
        <div class="dot" data-slide="1"></div>
        <div class="dot" data-slide="2"></div>
        <div class="dot" data-slide="3"></div>
        <div class="dot" data-slide="4"></div>
      {% endif %}
    </div>
  </div>
</div>
