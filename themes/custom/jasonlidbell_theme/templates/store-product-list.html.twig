<div class="store-page">

  <div class="product-grid">

    {% for product in products %}

      <div class="product-card">

        <h3>{{ product.title.value }}</h3>

        {# Product image #}
        {% if product.field_image.entity %}
          <img src="{{ file_url(product.field_image.entity.fileuri) }}" />
        {% endif %}

        {# Price #}
        {% if product.variations.entity %}
          <p>
            {{ product.variations.entity.price.number }} 
            {{ product.variations.entity.price.currency_code }}
          </p>
        {% endif %}

        <a href="/product/{{ product.id }}" class="btn">View Product</a>

      </div>

    {% endfor %}

  </div>

  {# Pagination #}
  <div class="pagination">
    {{ pager }}
  </div>

</div>