{#
/**
 * @file
 * Product teaser template for store grid display
 * Displays individual product card with image, price, and details
 */
#}

<article{{ attributes.addClass('product-card') }}>
  <div class="product-card-inner">

    {# Product Image Section #}
    <div class="product-card-image">
      {% if product.field_image.0 %}
        {% set image = product.field_image.0.entity %}
        <img src="{{ file_url(image.uri.value) }}"
             alt="{{ product.field_image.0.alt ?: product.title.value }}"
             class="card-img"
             loading="lazy">
      {% else %}
        <div class="card-img-placeholder">📷</div>
      {% endif %}

      {# Hover Overlay #}
      <div class="product-card-overlay">
        <a href="{{ url('entity.commerce_product.canonical', {'commerce_product': product.product_id.value}) }}"
           class="card-view-btn">
          View Details
        </a>
      </div>
    </div>

    {# Product Content Section #}
    <div class="product-card-content">
      
      {# Title #}
      <h3 class="product-card-title">{{ product.title.value }}</h3>

      {# Price #}
      {% if product.field_price.0 %}
        {% set price = product.field_price.0 %}
        <div class="product-card-price">
          <span class="card-price-symbol">
            {% if price.currency_code == 'USD' %}$
            {% elseif price.currency_code == 'EUR' %}€
            {% elseif price.currency_code == 'GBP' %}£
            {% elseif price.currency_code == 'INR' %}₹
            {% elseif price.currency_code == 'JPY' %}¥
            {% else %}{{ price.currency_code }}
            {% endif %}
          </span>
          <span class="card-price-amount">{{ price.number }}</span>
        </div>
      {% endif %}

      {# Description #}
      {% if product.body.value %}
        <div class="product-card-desc">
          {{ product.body.value|striptags|truncate(100, true) }}
        </div>
      {% endif %}

      {# Button #}
      <a href="{{ url('entity.commerce_product.canonical', {'commerce_product': product.product_id.value}) }}"
         class="card-add-btn">
        → View Product
      </a>

    </div>

  </div>
</article>
