{#
/**
 * @file
 * Store page template - Display all products in 3-column grid
 */
#}

<div class="store-page">
  <div class="store-container">

    {# Store Header #}
    <div class="store-header">
      <h1 class="store-title">Our Products</h1>
      <p class="store-subtitle">Explore our collection of premium products</p>
    </div>

    {# Filters & Sorting (Optional) #}
    <div class="store-controls">
      <div class="store-filters">
        {# Add filters here if needed #}
      </div>
    </div>

    {# Products Grid #}
    <div class="products-grid">
      {{ content }}
    </div>

  </div>
</div>
