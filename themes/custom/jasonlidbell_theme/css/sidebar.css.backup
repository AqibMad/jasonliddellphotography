/* Sidebar Entry Animation */
@keyframes slideInFromLeft {
    0% { transform: translateX(-110%); opacity: 0; }
    100% { transform: translateX(0); opacity: 1; }
}

/* Sidebar - Height starts as auto to wrap the logo */
.sidebar {
    position: fixed;
    top: 20px;
    left: 20px;
    width: 270px;
    height: auto; 
    background: rgba(0, 0, 0, 0.95);
    z-index: 1000;
    border-radius: 30px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.8);
    overflow: hidden;
    backdrop-filter: blur(10px);
    
    /* Initial Entrance Animation */
    animation: slideInFromLeft 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    
    /* Transition for expanding height */
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Expanded State - when clicked */
.sidebar.active {
    height: calc(100vh - 40px);
}

/* Sidebar Header */
.sidebar-header {
    padding: 30px 20px 25px;
    text-align: center;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 100%);
    cursor: pointer;
}

.sidebar-header img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
}

.logo-ornament-top, .logo-ornament-bottom {
    font-family: 'Georgia', serif;
    font-size: 1.8rem;
    color: #fff;
    font-weight: 300;
}

.logo-ornament-top { 
    margin-bottom: 5px; 
}

.logo-ornament-bottom { 
    margin-top: 5px; 
}

.sidebar-logo-name {
    font-family: 'Brush Script MT', cursive;
    font-size: 2.2rem;
    color: #fff;
    font-style: italic;
    margin-bottom: 3px;
    line-height: 1;
}

.sidebar-tagline {
    font-family: Arial, sans-serif;
    font-size: 0.75rem;
    color: #ccc;
    letter-spacing: 4px;
    font-weight: 300;
}

.menu-toggle-btn {
    padding: 12px;
    text-align: center;
    cursor: pointer;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    transition: background 0.3s;
    user-select: none;
    background: rgba(255,255,255,0.02);
}

.menu-toggle-btn:hover { 
    background: rgba(255,255,255,0.08); 
}

.menu-title {
    font-family: 'Georgia', serif;
    font-size: 1.2rem;
    color: #fff;
    letter-spacing: 2px;
    font-weight: 300;
}

/* Navigation Menu - Hidden initially on all pages */
.nav-menu {
    height: 0;
    opacity: 0;
    overflow-y: auto;
    padding: 0;
    transition: opacity 0.3s ease, height 0.3s ease;
}

/* Shown when sidebar is active */
.sidebar.active .nav-menu {
    height: calc(100% - 150px);
    opacity: 1;
    padding: 10px 0 40px 0;
}

/* Custom Scrollbar */
.nav-menu::-webkit-scrollbar { 
    width: 6px; 
}

.nav-menu::-webkit-scrollbar-track { 
    background: rgba(255,255,255,0.05); 
}

.nav-menu::-webkit-scrollbar-thumb { 
    background: rgba(75, 150, 200, 0.5); 
    border-radius: 3px; 
}

.nav-menu::-webkit-scrollbar-thumb:hover { 
    background: rgba(75, 150, 200, 0.8); 
}

/* Drupal menu list styling */
.nav-menu .menu,
.nav-menu ul,
.nav-list { 
    list-style: none;
    margin: 0;
    padding: 0;
}

/* Nav items - both custom and Drupal classes */
.nav-item,
.nav-menu .menu-item {
    opacity: 0;
    transform: translateX(-20px);
    margin: 0;
    padding: 0;
}

/* Animate when sidebar is active */
.sidebar.active .nav-item,
.sidebar.active .nav-menu .menu-item {
    animation: slideInNav 0.4s forwards;
}

@keyframes slideInNav { 
    to { 
        opacity: 1; 
        transform: translateX(0); 
    } 
}

.nav-item:nth-child(1) { animation-delay: 0.05s; }
.nav-item:nth-child(2) { animation-delay: 0.08s; }
.nav-item:nth-child(3) { animation-delay: 0.11s; }
.nav-item:nth-child(4) { animation-delay: 0.14s; }
.nav-item:nth-child(5) { animation-delay: 0.17s; }
.nav-item:nth-child(6) { animation-delay: 0.20s; }
.nav-item:nth-child(7) { animation-delay: 0.23s; }
.nav-item:nth-child(8) { animation-delay: 0.26s; }
.nav-item:nth-child(9) { animation-delay: 0.29s; }
.nav-item:nth-child(10) { animation-delay: 0.32s; }
.nav-item:nth-child(11) { animation-delay: 0.35s; }
.nav-item:nth-child(12) { animation-delay: 0.38s; }
.nav-item:nth-child(13) { animation-delay: 0.41s; }
.nav-item:nth-child(14) { animation-delay: 0.44s; }
.nav-item:nth-child(15) { animation-delay: 0.47s; }
.nav-item:nth-child(16) { animation-delay: 0.50s; }
.nav-item:nth-child(17) { animation-delay: 0.53s; }
.nav-item:nth-child(18) { animation-delay: 0.56s; }

/* Drupal menu items */
.nav-menu .menu-item:nth-child(1) { animation-delay: 0.05s; }
.nav-menu .menu-item:nth-child(2) { animation-delay: 0.08s; }
.nav-menu .menu-item:nth-child(3) { animation-delay: 0.11s; }
.nav-menu .menu-item:nth-child(4) { animation-delay: 0.14s; }
.nav-menu .menu-item:nth-child(5) { animation-delay: 0.17s; }
.nav-menu .menu-item:nth-child(6) { animation-delay: 0.20s; }
.nav-menu .menu-item:nth-child(7) { animation-delay: 0.23s; }
.nav-menu .menu-item:nth-child(8) { animation-delay: 0.26s; }
.nav-menu .menu-item:nth-child(9) { animation-delay: 0.29s; }
.nav-menu .menu-item:nth-child(10) { animation-delay: 0.32s; }
.nav-menu .menu-item:nth-child(11) { animation-delay: 0.35s; }
.nav-menu .menu-item:nth-child(12) { animation-delay: 0.38s; }
.nav-menu .menu-item:nth-child(13) { animation-delay: 0.41s; }
.nav-menu .menu-item:nth-child(14) { animation-delay: 0.44s; }
.nav-menu .menu-item:nth-child(15) { animation-delay: 0.47s; }
.nav-menu .menu-item:nth-child(16) { animation-delay: 0.50s; }
.nav-menu .menu-item:nth-child(17) { animation-delay: 0.53s; }
.nav-menu .menu-item:nth-child(18) { animation-delay: 0.56s; }

/* Link styling - targets both custom and Drupal classes */
.nav-link,
.nav-menu a,
.nav-menu .menu-link {
    display: block;
    padding: 8px 0;
    color: #fff;
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    transition: all 0.3s;
    font-family: Arial, sans-serif;
    font-weight: 300;
    text-align: center;
    line-height: 1.3;
}

.nav-link:hover, 
.nav-link.active,
.nav-link.is-active,
.nav-menu a:hover,
.nav-menu a.is-active,
.nav-menu .menu-link:hover,
.nav-menu .menu-link.is-active {
    color: rgba(75, 150, 200, 1);
    font-weight: 400;
}

.sidebar-tab {
    position: absolute;
    right: -50px;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 120px;
    background: rgba(0, 0, 0, 0.9);
    border-radius: 0 15px 15px 0;
    box-shadow: 0 0 0 3px rgba(75, 150, 200, 0.6);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    opacity: 0;
    pointer-events: none;
}

.sidebar.collapsed .sidebar-tab {
    opacity: 1;
    pointer-events: all;
}

.sidebar-tab:hover {
    right: -45px;
    background: rgba(75, 150, 200, 0.3);
}

.tab-icon {
    width: 30px;
    height: 2px;
    background: #fff;
    position: relative;
}

.tab-icon::before, .tab-icon::after {
    content: '';
    position: absolute;
    width: 30px;
    height: 2px;
    background: #fff;
    left: 0;
}

.tab-icon::before { 
    top: -8px; 
}

.tab-icon::after { 
    bottom: -8px; 
}

@media (max-width: 768px) {
    .sidebar {
        width: 280px;
        left: -280px; /* Hidden by default on mobile */
        top: 0;
        height: 100vh;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 0 15px 15px 0;
        z-index: 1001;
    }
    
    .sidebar.active {
        left: 0; /* Slide in when active */
        height: 100vh;
    }
    
    /* Mobile hamburger menu button */
    .mobile-menu-toggle {
        position: fixed;
        top: 20px;
        left: 20px;
        width: 50px;
        height: 50px;
        background: rgba(0, 0, 0, 0.9);
        border-radius: 50%;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.8);
        border: 2px solid rgba(75, 150, 200, 0.6);
        transition: all 0.3s;
    }
    
    .mobile-menu-toggle:hover {
        background: rgba(75, 150, 200, 0.3);
        border-color: rgba(75, 150, 200, 1);
    }
    
    .mobile-menu-toggle.active {
        left: 300px; /* Move with sidebar */
    }
    
    /* Hamburger icon */
    .hamburger-icon {
        width: 24px;
        height: 2px;
        background: #fff;
        position: relative;
        transition: all 0.3s;
    }
    
    .hamburger-icon::before,
    .hamburger-icon::after {
        content: '';
        position: absolute;
        width: 24px;
        height: 2px;
        background: #fff;
        transition: all 0.3s;
    }
    
    .hamburger-icon::before {
        top: -8px;
    }
    
    .hamburger-icon::after {
        bottom: -8px;
    }
    
    /* Transform to X when active */
    .mobile-menu-toggle.active .hamburger-icon {
        background: transparent;
    }
    
    .mobile-menu-toggle.active .hamburger-icon::before {
        top: 0;
        transform: rotate(45deg);
    }
    
    .mobile-menu-toggle.active .hamburger-icon::after {
        bottom: 0;
        transform: rotate(-45deg);
    }
    
    /* Hide sidebar tab on mobile */
    .sidebar-tab {
        display: none;
    }
}

/* Smaller mobile phones */
@media (max-width: 480px) {
    .sidebar {
        width: 260px;
        left: -260px;
    }
    
    .mobile-menu-toggle.active {
        left: 280px;
    }
    
    .sidebar-header {
        padding: 20px 15px 20px;
    }
    
    .sidebar-logo-name {
        font-size: 1.8rem;
    }
    
    .nav-link,
    .nav-menu a,
    .nav-menu .menu-link {
        font-size: 0.7rem;
        padding: 6px 0;
    }
}
